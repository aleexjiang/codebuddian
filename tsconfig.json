{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2022",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": [
			"DOM",
			"ES2022"
		],
		"paths": {
			"@core/*": ["src/core/*"],
			"@providers/*": ["src/providers/*"],
			"@features/*": ["src/features/*"],
			"@shared/*": ["src/shared/*"],
			"@utils/*": ["src/utils/*"],
			"@i18n/*": ["src/i18n/*"],
			"@app/*": ["src/app/*"]
		}
	},
	"include": [
		"src/**/*.ts"
	]
}
